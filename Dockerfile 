# ── BidPilot Worker (Railway) ────────────────────────────────────────────────
# Single-stage. node:22-bookworm-slim ALWAYS exists (no version-pinned image tag
# to get wrong). `playwright install --with-deps chromium` puts Chromium AND its
# system libraries (libglib, libnss, …) into THIS image → no libglib errors.
FROM node:22-bookworm-slim

WORKDIR /app

# Browser co-located with the package (matches PLAYWRIGHT_BROWSERS_PATH=0).
ENV PLAYWRIGHT_BROWSERS_PATH=0

# Install deps with npm (built into the image — no corepack/network surprises).
# Copy only package.json so a lockfile mismatch can never fail the build.
COPY package.json ./
RUN npm install --legacy-peer-deps --no-audit --no-fund

COPY . .

# THE KEY LINE: Chromium + all required system libraries into this image.
RUN npx playwright install --with-deps chromium

ENV NODE_ENV=production
CMD ["npx", "tsx", "worker/index.ts"]